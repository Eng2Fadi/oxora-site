{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/generate", "dest": "/api/generate.js" },
    { "src": "/api/contact",  "dest": "/api/contact.js"  },
    { "src": "/api/stats",    "dest": "/api/stats.js"    },
    { "src": "/(.*)",         "dest": "/index.html"      }
  ]
}
